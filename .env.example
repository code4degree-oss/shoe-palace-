# ==========================================
# Kesurved Herbal — Production Environment
# ==========================================
# Copy this file to .env on your VM and fill in the values.
# cp .env.example .env && nano .env

# ─── Database ────────────────────────────────────────────
# Your PostgreSQL connection string on the VM.
# Replace user, password, host, port, and dbname with your actual values.
DATABASE_URL="postgresql://kesurved_user:YOUR_STRONG_PASSWORD@localhost:5432/kesurved_db?sslmode=disable&connection_limit=5"

# ─── Razorpay (Payment Gateway) ─────────────────────────
# Get these from https://dashboard.razorpay.com → Settings → API Keys
# Use TEST keys during testing, LIVE keys for production.
RAZORPAY_KEY_ID="rzp_live_XXXXXXXXXXX"
RAZORPAY_KEY_SECRET="XXXXXXXXXXXXXXXXXXXXXXXX"

# ─── App Config ──────────────────────────────────────────
NODE_ENV="production"
PORT=3000

# ─── Admin Login ─────────────────────────────────────────
# Change these to secure values on your server!
ADMIN_EMAIL="admin@kesurved.com"
ADMIN_PASSWORD="YOUR_STRONG_ADMIN_PASSWORD"
JWT_SECRET="YOUR_RANDOM_SECRET_KEY_MIN_32_CHARS"

# ─── WhatsApp Cloud API (Optional) ──────────────────────
# Get these from https://developers.facebook.com → WhatsApp → API Setup
# If not set, WhatsApp notifications will be silently skipped.
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_BUSINESS_ACCOUNT_ID=""

